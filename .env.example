# ─── DATABASE ────────────────────────────────────────────────────────────────
# IMPORTANT:
#  - Inside Docker, the host MUST be 'postgres' (the docker-compose service name).
#  - Outside Docker (local dev), use 'localhost'.
#  - The password in DATABASE_URL MUST match POSTGRES_PASSWORD below.
#  - If you change POSTGRES_PASSWORD after the postgres volume is initialised,
#    run `docker compose down -v` to reset the volume (DESTROYS DATA).
DATABASE_URL="postgresql://dharsan:dharsan_dev_2026@postgres:5432/dharsan_dresses"

# ─── POSTGRES (docker-compose) ───────────────────────────────────────────────
POSTGRES_USER=dharsan
POSTGRES_PASSWORD=dharsan_dev_2026
POSTGRES_DB=dharsan_dresses

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-32-char-random-string
# Testing (IP only, no domain):
NEXTAUTH_URL=http://YOUR_OCI_IP
# Production (with domain):
# NEXTAUTH_URL=https://dharsandresses.com

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://YOUR_OCI_IP
NEXT_PUBLIC_APP_NAME=Dharsan Dresses
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=1000
NEXT_PUBLIC_PHONE=+91XXXXXXXXXX
NEXT_PUBLIC_EMAIL=info@dharsandresses.com
NEXT_PUBLIC_ADDRESS=Yadava St, Varadaraja Nagar, Tirupati, Andhra Pradesh 517501
NEXT_PUBLIC_INSTAGRAM=https://www.instagram.com/dharsandresses/
NEXT_PUBLIC_YOUTUBE=https://www.youtube.com/@dharsandresses

