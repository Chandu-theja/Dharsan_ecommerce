# ─── DATABASE ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:5432/dharsan_dresses
DATABASE_URL="postgresql://dharsan:CHANGE_THIS_PASSWORD@localhost:5432/dharsan_dresses"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="GENERATE_STRONG_SECRET_HERE"
NEXTAUTH_URL="https://yourdomain.com"
# For local development:
# NEXTAUTH_URL="http://localhost:3000"

# ─── RAZORPAY ─────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_live_XXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXX"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_live_XXXXXXXXXX"

# ─── EMAIL (Gmail SMTP) ───────────────────────────────────────────────────────
# Enable 2FA on Gmail, then create App Password:
# Google Account → Security → App passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-business-email@gmail.com"
SMTP_PASSWORD="your-gmail-app-password"
SMTP_FROM="Dharsan Dresses <orders@dharsandresses.com>"

# ─── WHATSAPP (Twilio) ────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
# Free trial available — good for testing
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886" # Twilio sandbox number
SHOP_WHATSAPP_NUMBER="whatsapp:+91XXXXXXXXXX" # Your WhatsApp Business number

# ─── DELHIVERY API ────────────────────────────────────────────────────────────
# Get from Delhivery merchant dashboard
DELHIVERY_API_TOKEN="your-delhivery-api-token"
DELHIVERY_API_URL="https://track.delhivery.com"

# ─── FILE STORAGE ─────────────────────────────────────────────────────────────
# Option 1: OCI Object Storage (Free with OCI always free tier)
OCI_NAMESPACE="your-oci-namespace"
OCI_BUCKET_NAME="dharsan-dresses-media"
OCI_REGION="ap-mumbai-1"
OCI_ACCESS_KEY="your-oci-access-key"
OCI_SECRET_KEY="your-oci-secret-key"

# Option 2: Cloudflare R2 (10GB free/month — recommended for small stores)
# R2_ACCOUNT_ID="your-cloudflare-account-id"
# R2_ACCESS_KEY_ID="your-r2-access-key"
# R2_SECRET_ACCESS_KEY="your-r2-secret-key"
# R2_BUCKET_NAME="dharsan-dresses"
# NEXT_PUBLIC_R2_PUBLIC_URL="https://your-r2-public-url.r2.dev"

# Storage provider to use: 'oci' or 'r2'
STORAGE_PROVIDER="oci"
NEXT_PUBLIC_MEDIA_URL="https://objectstorage.ap-mumbai-1.oraclecloud.com/n/YOUR_NAMESPACE/b/dharsan-dresses-media/o"

# ─── ADMIN ────────────────────────────────────────────────────────────────────
# Secret for protecting admin seeding routes
ADMIN_SECRET="CHANGE_THIS_TO_STRONG_SECRET"

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
NEXT_PUBLIC_APP_NAME="Dharsan Dresses"
NEXT_PUBLIC_PHONE="+91 XXXXXXXXXX"
NEXT_PUBLIC_EMAIL="info@dharsandresses.com"
NEXT_PUBLIC_ADDRESS="Yadava St, Varadaraja Nagar, Tirupati, Andhra Pradesh 517501"
NEXT_PUBLIC_INSTAGRAM="https://www.instagram.com/dharsandresses/"
NEXT_PUBLIC_YOUTUBE="https://www.youtube.com/@dharsandresses"
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=1000
